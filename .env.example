# Secrets and per-install values for docker-compose.yaml. Static config -
# versions, ports, schedules - lives in the compose file, not here.
# Copy to .env and fill in. .env is gitignored and must stay that way.

# ProtonVPN
# From account.protonvpn.com -> Downloads -> WireGuard configuration.
# Only the two [Interface] values are needed; the [Peer] block is not, because
# gluetun resolves a server from SERVER_COUNTRIES.
# Pick a plain UK server, not Secure Core or Tor.
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=10.2.0.2/32
# Both sources are .co.uk and serve UK catalogues; another exit risks a
# geo-redirect that would quietly poison the scrape.
SERVER_COUNTRIES=United Kingdom

# Postgres
# Generate: pwgen -s 40 1
POSTGRES_PASSWORD=
POSTGRES_USER=mealplanmcp
POSTGRES_DB=mealplanmcp

# Docker network
# Must match the range gluetun is told to allow through its killswitch, or the
# scraper cannot reach Postgres. Change only if it clashes with an existing
# network on the host.
DOCKER_SUBNET=172.28.0.0/16
